<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Ciclo de Vida Institucional del Estudiante UTE</title>
    <script src="https://cdn.tailwindcss.com">
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js">
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#fff7ed',
                            100: '#ffedd5',
                            200: '#fed7aa',
                            300: '#fdba74',
                            400: '#fb923c',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                            800: '#9a3412',
                            900: '#7c2d12',
                        },
                        ui: {
                            bg: '#f8fafc',
                            card: '#ffffff',
                            border: '#e2e8f0',
                            textMain: '#1e293b',
                            textMuted: '#64748b',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #f8fafc;
            color: #1e293b;
            letter-spacing: -0.01em;
        }
        .glass-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 1.25rem;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.01);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            border-color: #fdba74;
            box-shadow: 0 10px 15px -3px rgba(251, 146, 60, 0.08);
        }
        .pulse-dot {
            animation: pulse-dot 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse-dot {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.5);
            }
            50% {
                box-shadow: 0 0 0 10px rgba(249, 115, 22, 0);
            }
        }
        .fade-in {
            animation: fadeInUp 0.4s ease forwards;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .tab-active {
            background-color: #ffedd5 !important;
            border-color: #f97316 !important;
            color: #c2410c !important;
        }
        .tab-active i {
            color: #ea580c !important;
        }
        .tab-active span.font-mono {
            color: #f97316 !important;
        }
        .field-tag {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            padding: 0.3rem 0.8rem;
            font-size: 0.7rem;
            font-weight: 500;
            color: #0f172a;
            transition: all 0.15s;
        }
        .field-tag:hover {
            background: #ffedd5;
            border-color: #fdba74;
            color: #9a3412;
        }
        .accordion-header {
            cursor: pointer;
            transition: background 0.2s;
        }
        .accordion-header:hover {
            background: #fef9c3;
        }
        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
        }
        .accordion-content.open {
            max-height: 800px;
            transition: max-height 0.4s ease-in;
        }
        .viewport {
            cursor: grab;
            touch-action: none;
        }
        .viewport:active {
            cursor: grabbing;
        }
        .mermaid-wrapper {
            transform-origin: 0 0;
            transition: transform 0.05s linear;
            width: fit-content;
            min-width: 100%;
        }
        .mermaid {
            background: white;
            margin: 0;
            padding: 1rem;
            display: flex;
            justify-content: center;
        }
        .diagram-container {
            overflow: hidden;
        }
        .badge-dep {
            display: inline-block;
            background: #f1f5f9;
            border-radius: 999px;
            padding: 0.1rem 0.6rem;
            font-size: 0.6rem;
            font-weight: 600;
            color: #0f172a;
            border: 1px solid #e2e8f0;
        }
        .badge-dep:hover {
            background: #ffedd5;
            border-color: #fdba74;
        }
        .status-badge {
            display: inline-block;
            padding: 0.15rem 0.6rem;
            border-radius: 999px;
            font-size: 0.6rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .status-validado {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }
        .status-parcial {
            background: #fef9c3;
            color: #854d0e;
            border: 1px solid #fde047;
        }
        .status-pendiente {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }
        .risk-critical {
            border-left: 4px solid #ef4444;
        }
        .risk-high {
            border-left: 4px solid #f97316;
        }
        .risk-medium {
            border-left: 4px solid #eab308;
        }
        .risk-low {
            border-left: 4px solid #94a3b8;
        }
        /* Ajustes para que el texto del diagrama sea más grande */
        .mermaid .label {
            font-size: 14px !important;
            font-weight: 500;
        }
        .mermaid .nodeLabel {
            font-size: 14px !important;
        }
        .mermaid .edgeLabel {
            font-size: 12px !important;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col antialiased font-sans text-ui-textMain">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-ui-border">
        <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 flex flex-col sm:flex-row justify-between items-center gap-3">
            <div class="flex items-center gap-3.5">
                <div class="w-11 h-11 rounded-2xl bg-brand-500 flex items-center justify-center shadow-md shadow-brand-500/20">
                    <i class="fa-solid fa-graduation-cap text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-lg md:text-xl font-extrabold tracking-tighter text-slate-950 leading-tight">
                        Ecosistema Institucional del Estudiante <span class="text-brand-600">UTE</span>
                    </h1>
                    <p class="text-[11px] text-ui-textMuted flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-brand-500 pulse-dot inline-block"></span>
                        Modelo integrado TSU → Lic./Ing. · 9 fases · 5 modalidades · 218 campos · 8 departamentos propietarios
                        <span class="ml-2 text-[9px] bg-slate-100 px-2 py-0.5 rounded-full text-slate-600 font-medium">v3.0 · Jun 2026</span>
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-2 text-[10px] text-ui-textMuted bg-slate-50 px-3 py-1.5 rounded-full border border-ui-border">
                <i class="fa-regular fa-file-lines text-brand-500"></i>
                <span>Reporte técnico integrado</span>
                <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                <span>218 campos · 12 deptos.</span>
            </div>
        </div>
    </header>
    <main class="flex-grow max-w-7xl w-full mx-auto p-4 md:p-6 space-y-6">

        <!-- MAPA VISUAL -->
        <section class="glass-card p-5 md:p-6">
            <div class="flex items-center gap-3 mb-5 border-b border-ui-border pb-4">
                <span class="w-9 h-9 rounded-xl bg-brand-100 flex items-center justify-center">
                    <i class="fa-solid fa-sitemap text-brand-600 text-base"></i>
                </span>
                <div>
                    <h2 class="text-base font-bold text-slate-950">Mapa visual del ciclo de vida institucional</h2>
                    <p class="text-xs text-ui-textMuted">Flujo institucional desde el registro inicial del interesado hasta el seguimiento de egresados TSU y Lic./Ing.</p>
                </div>
            </div>
            <div class="diagram-container" style="border:1px solid #e2e8f0; border-radius:0.75rem; background:#f8fafc; overflow:hidden;">
                <div class="toolbar" style="display:flex; align-items:center; gap:8px; padding:8px 12px; background:white; border-bottom:1px solid #e2e8f0; flex-wrap:wrap;">
                    <div style="display:flex; align-items:center; gap:2px; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:8px; padding:2px;">
                        <button class="zoom-in" style="width:30px; height:28px; border:none; background:none; cursor:pointer; border-radius:6px; font-size:18px; font-weight:bold; color:#475569;">+</button>
                        <span class="zoom-level" style="font-size:10px; font-family:monospace; min-width:45px; text-align:center;">100%</span>
                        <button class="zoom-out" style="width:30px; height:28px; border:none; background:none; cursor:pointer; border-radius:6px; font-size:18px; font-weight:bold; color:#475569;">−</button>
                    </div>
                    <button class="fit-view" style="height:30px; padding:0 12px; border:1px solid #e2e8f0; background:white; border-radius:8px; font-size:11px; font-weight:500; cursor:pointer;">⟳ Ajustar vista</button>
                    <button class="reset-view" style="height:30px; padding:0 12px; border:1px solid #e2e8f0; background:white; border-radius:8px; font-size:11px; font-weight:500; cursor:pointer;">Restablecer</button>
                    <div style="margin-left:auto; display:flex; align-items:center; gap:10px; font-size:9px; color:#64748b;">
                        <span>🖱️ Arrastra · Rueda zoom</span>
                    </div>
                </div>
                <div class="viewport" style="position:relative; height:700px; overflow:hidden; cursor:grab; background:#f8fafc;" id="mermaid-viewport">
                    <div class="mermaid-wrapper" style="transform-origin: 0 0;">
                        <pre class="mermaid">
                            flowchart TD
                                classDef ingreso fill:#fff7ed,stroke:#fb923c,stroke-width:2px,color:#7c2d12;
                                classDef tsu fill:#f0f9ff,stroke:#38bdf8,stroke-width:2px,color:#075985;
                                classDef estadia fill:#ecfdf5,stroke:#10b981,stroke-width:2px,color:#065f46;
                                classDef titulacion fill:#fffbeb,stroke:#f59e0b,stroke-width:2px,color:#92400e;
                                classDef superior fill:#f5f3ff,stroke:#8b5cf6,stroke-width:2px,color:#4c1d95;
                                classDef egresado fill:#f0fdfa,stroke:#14b8a6,stroke-width:2px,color:#0f766e;
                                classDef baja fill:#fef2f2,stroke:#ef4444,stroke-width:2px,color:#991b1b;
                                classDef decision fill:#ffffff,stroke:#64748b,stroke-width:2px,color:#0f172a;

                                A["FASE 1<br><b>Interesado</b><br/>Captación, difusión y registro inicial"]:::ingreso
                                B["FASE 2<br><b>Aspirante</b><br/>Registro formal, expediente y examen de admisión"]:::ingreso
                                C{"¿Admitido?"}:::decision

                                A --> B
                                B --> C

                                C -->|No acreditado| Z1["Fin del proceso<br/>Prospecto no admitido"]:::baja
                                C -->|Baja académica o personal| Z2["Baja previa a inscripción<br/>Retiro voluntario o administrativo"]:::baja

                                C -->|Admitido| D["FASE 3<br><b>Alumno TSU</b><br/>Matrícula, carrera, grupo, turno y modalidad"]:::tsu

                                D --> D1{"Plan TSU"}:::decision
                                D1 -->|Nuevo Modelo Educativo| D2["TSU NME<br/>Ordinario · Revaluación · Especial"]:::tsu
                                D1 -->|Plan en liquidación| D3["TSU en liquidación<br/>Ordinario · Revaluación"]:::tsu

                                D2 --> E["Ciclo académico TSU<br/>Inscripción · Clases · Evaluación · Reinscripción"]:::tsu
                                D3 --> E

                                E --> E1{"Resultado académico TSU"}:::decision
                                E1 -->|Aprobado| E2["Reinscripción<br/>al siguiente cuatrimestre"]:::tsu
                                E2 --> E

                                E1 -->|Créditos completos| F["FASE 4<br><b>Estadía práctica TSU</b><br/>Proyecto técnico en empresa"]:::estadia

                                E1 -->|Reprobación definitiva| Z3["Baja TSU<br/>Causa académica"]:::baja
                                E1 -->|Baja personal, financiera o administrativa| Z4["Baja TSU<br/>Temporal o definitiva"]:::baja

                                F --> F1["Registro de proyecto TSU<br/>Empresa · Asesor empresarial · Asesor académico"]:::estadia
                                F1 --> F2["Desarrollo de bitácoras<br/>Evidencias y seguimiento"]:::estadia
                                F2 --> F3["Entrega de memoria técnica<br/>Revisión y correcciones"]:::estadia
                                F3 --> F4{"¿Estadía TSU liberada?"}:::decision

                                F4 -->|No| F5["Regularización de estadía TSU<br/>Corrección de evidencias o recursamiento"]:::estadia
                                F5 --> F2

                                F4 -->|Sí| G["FASE 5<br><b>Titulación TSU</b><br/>Título y cédula profesional TSU"]:::titulacion

                                G --> G1["Revisión integral<br/>del expediente TSU"]:::titulacion
                                G1 --> G2["Registro ante DGP-SEP<br/>Folio, título y cédula TSU"]:::titulacion
                                G2 --> H{"¿Continúa a Lic./Ing.?"}:::decision

                                H -->|No| I["<b>Egresado TSU</b><br/>Inserción laboral, bolsa de trabajo o educación continua"]:::egresado
                                I --> S["FASE 9<br><b>Seguimiento de egresados</b><br/>TSU y Lic./Ing."]:::egresado

                                H -->|Sí| J["FASE 6<br><b>Alumno Lic./Ing.</b><br/>Continuidad con cédula TSU"]:::superior

                                J --> J1{"Plan superior"}:::decision
                                J1 -->|Nuevo Modelo Educativo| J2["Lic./Ing. NME<br/>Ordinario · Revaluación · Especial"]:::superior
                                J1 -->|Plan en liquidación| J3["Lic./Ing. en liquidación<br/>Ordinario · Revaluación"]:::superior

                                J2 --> K["Ciclo académico Lic./Ing.<br/>Inscripción · Clases · Evaluación · Reinscripción"]:::superior
                                J3 --> K

                                K --> K1{"Resultado académico Lic./Ing."}:::decision
                                K1 -->|Aprobado| K2["Reinscripción<br/>al siguiente cuatrimestre"]:::superior
                                K2 --> K

                                K1 -->|5 cuatrimestres completos| L["FASE 7<br><b>Estadía profesional superior</b><br/>Proyecto profesional en empresa"]:::estadia

                                K1 -->|Reprobación definitiva| Z5["Baja Lic./Ing.<br/>Causa académica"]:::baja
                                K1 -->|Baja personal, financiera o administrativa| Z6["Baja Lic./Ing.<br/>Temporal o definitiva"]:::baja

                                L --> L1["Registro de proyecto superior<br/>Empresa · Asesor empresarial · Asesor académico"]:::estadia
                                L1 --> L2["Bitácoras y evidencias avanzadas<br/>Seguimiento académico y empresarial"]:::estadia
                                L2 --> L3["Entrega de memoria de grado<br/>Revisión académica"]:::estadia
                                L3 --> L4{"¿Estadía superior liberada?"}:::decision

                                L4 -->|No| L5["Regularización de estadía superior<br/>Corrección o recursamiento"]:::estadia
                                L5 --> L2

                                L4 -->|Sí| M["FASE 8<br><b>Titulación Lic./Ing.</b><br/>Título y cédula profesional"]:::titulacion

                                M --> M1["Revisión integral<br/>del expediente Lic./Ing."]:::titulacion
                                M1 --> M2["Registro ante DGP-SEP<br/>Folio, título y cédula profesional"]:::titulacion
                                M2 --> N["<b>Egresado Lic./Ing.</b><br/>Licenciado o Ingeniero"]:::egresado
                                N --> S

                                S --> S1["Bolsa de Trabajo UTGE<br/>Vacantes, referidos y vinculación laboral"]:::egresado
                                S --> S2["Encuestas de empleabilidad<br/>Actualización de trayectoria profesional"]:::egresado
                                S --> S3["Encuestas a empleadores<br/>Pertinencia del perfil de egreso"]:::egresado
                                S --> S4["Educación continua<br/>Diplomados · Cursos · Posgrados"]:::egresado
                                S --> S5["Indicadores MIR y KPI institucionales<br/>Egreso, titulación y empleabilidad"]:::egresado
                        </pre>
                    </div>
                </div>
            </div>
        </section>

        <!-- FILA SUPERIOR: Fases + Modalidades + Requisitos -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <aside class="lg:col-span-4 flex flex-col gap-5">
                <!-- Fases -->
                <div class="glass-card p-4">
                    <h3 class="text-sm font-bold text-slate-950 mb-3.5 flex items-center gap-2.5">
                        <i class="fa-solid fa-layer-group text-brand-500"></i>
                        Fases del ciclo de vida
                    </h3>
                    <nav id="phase-tabs" class="flex flex-col gap-1.5"></nav>
                </div>
                <!-- Modalidades -->
                <div class="glass-card p-4 border-l-4 border-l-brand-400">
                    <h3 class="text-sm font-bold text-slate-950 mb-3 flex items-center gap-2">
                        <i class="fa-solid fa-clock text-brand-500"></i>
                        Modalidades académicas
                    </h3>
                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="showModality('TRADICIONAL')" class="mod-btn text-left p-2.5 bg-slate-50 border border-ui-border rounded-xl transition-all" data-mod="TRADICIONAL">
                            <span class="block font-semibold text-xs text-slate-900">Tradicional</span>
                            <span class="text-[10px] text-ui-textMuted">Presencial · 6 cuatrim.</span>
                        </button>
                        <button onclick="showModality('BIS')" class="mod-btn text-left p-2.5 bg-slate-50 border border-ui-border rounded-xl transition-all" data-mod="BIS">
                            <span class="block font-semibold text-xs text-slate-900">Bilingüe BIS</span>
                            <span class="text-[10px] text-ui-textMuted">Inglés · 7 cuatrim.</span>
                        </button>
                        <button onclick="showModality('DESPRESURIZADA')" class="mod-btn text-left p-2.5 bg-slate-50 border border-ui-border rounded-xl transition-all" data-mod="DESPRESURIZADA">
                            <span class="block font-semibold text-xs text-slate-900">Despresurizado</span>
                            <span class="text-[10px] text-ui-textMuted">Flexible · 8 cuatrim.</span>
                        </button>
                        <button onclick="showModality('MIXTA')" class="mod-btn text-left p-2.5 bg-slate-50 border border-ui-border rounded-xl transition-all" data-mod="MIXTA">
                            <span class="block font-semibold text-xs text-slate-900">Mixto híbrido</span>
                            <span class="text-[10px] text-ui-textMuted">Híbrido · 6 cuatrim.</span>
                        </button>
                        <button onclick="showModality('DUAL')" class="mod-btn text-left p-2.5 bg-slate-50 border border-ui-border rounded-xl transition-all col-span-2" data-mod="DUAL">
                            <span class="block font-semibold text-xs text-slate-900">Modelo dual</span>
                            <span class="text-[10px] text-ui-textMuted">Vinculación laboral activa con empresa</span>
                        </button>
                    </div>
                    <div id="modality-info" class="mt-3 p-3 bg-slate-50 rounded-xl border border-ui-border text-xs text-ui-textMain min-h-[60px]"></div>
                    <!-- Nota Dual del reporte -->
                    <div class="mt-2 text-[10px] text-amber-700 bg-amber-50 p-2 rounded-lg border border-amber-200 flex items-start gap-1.5">
                        <i class="fa-solid fa-triangle-exclamation text-amber-500 mt-0.5"></i>
                        <span><strong>Dual:</strong> Exclusiva TSU · Sin departamento independiente — campos distribuidos entre Escolares y Vinculación.</span>
                    </div>
                </div>
                <!-- Requisitos -->
                <div class="glass-card p-4 border-l-4 border-l-sky-400 bg-sky-50/50">
                    <h3 class="text-sm font-bold text-sky-950 mb-2.5 flex items-center gap-2">
                        <i class="fa-solid fa-clipboard-check text-sky-600"></i>
                        Requisitos de inscripción
                    </h3>
                    <ul class="text-[11px] space-y-1.5 text-sky-900 list-inside list-disc">
                        <li>Certificado de bachillerato original o kardex completo.</li>
                        <li>CURP impresa en formato reciente.</li>
                        <li>4 fotografías tamaño infantil en blanco y negro.</li>
                        <li>Comprobante de domicilio con antigüedad no mayor a 3 meses.</li>
                        <li>Certificado médico oficial.</li>
                        <li class="border-t border-sky-200 pt-1.5 mt-1 font-medium text-sky-700 list-none">
                            <i class="fa-solid fa-arrow-right text-xs mr-1"></i>
                            Para continuidad: cédula TSU y liberación de estadía.
                        </li>
                    </ul>
                    <!-- Estructura financiera del reporte -->
                    <div class="mt-3 pt-3 border-t border-sky-200 grid grid-cols-2 gap-2 text-[10px]">
                        <div class="bg-white/70 p-2 rounded-lg">
                            <p class="font-bold text-slate-800">TSU</p>
                            <p>Insc. $560 · Mens. $560 · Reins. $300</p>
                        </div>
                        <div class="bg-white/70 p-2 rounded-lg">
                            <p class="font-bold text-slate-800">Lic./Ing.</p>
                            <p>Insc. $800 · Mens. $800 · Reins. $400</p>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- COLUMNA DERECHA: Detalle de fase + Bajas -->
            <section class="lg:col-span-8 flex flex-col gap-6">
                <div id="phase-detail-viewer" class="glass-card p-5 md:p-6 min-h-[400px] fade-in"></div>
                <div class="glass-card p-5">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-4.5 border-b border-ui-border pb-4">
                        <h3 class="text-sm font-bold text-slate-950 flex items-center gap-2.5">
                            <i class="fa-solid fa-user-slash text-red-500"></i>
                            Catálogo institucional de causas de baja
                            <span class="text-[10px] bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-medium">23 motivos</span>
                        </h3>
                        <select id="baja-category-filter" onchange="renderBajas()" class="bg-white border border-ui-border text-xs rounded-lg px-3 py-1.5 text-ui-textMain focus:outline-none focus:border-red-300 focus:ring-1 focus:ring-red-100 transition-all cursor-pointer">
                            <option value="todos">Todas las categorías</option>
                            <option value="Socioemocional">Socioemocional</option>
                            <option value="Económico-laboral">Económico-laboral</option>
                            <option value="Académico">Académico</option>
                            <option value="Geográfico">Geográfico</option>
                            <option value="Otros">Otros</option>
