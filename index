        // ---- ZOOM Y PAN (con ajuste de zoom mínimo) ----
        (function() {
            const viewport = document.getElementById('mermaid-viewport');
            const wrapper = viewport?.querySelector('.mermaid-wrapper');
            if (!viewport || !wrapper) return;

            let scale = 1;
            let translateX = 0,
                translateY = 0;
            let isDragging = false;
            let startX, startY, startTranslateX, startTranslateY;

            function updateTransform() {
                wrapper.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
                const level = document.querySelector('.zoom-level');
                if (level) level.innerText = Math.round(scale * 100) + '%';
            }

            function zoomAt(delta, clientX, clientY) {
                const rect = viewport.getBoundingClientRect();
                const x = clientX - rect.left;
                const y = clientY - rect.top;
                const factor = delta > 0 ? 1.1 : 0.9;
                const newScale = Math.min(3, Math.max(0.4, scale * factor));
                if (newScale === scale) return;
                const dx = x - translateX;
                const dy = y - translateY;
                translateX = x - dx * (newScale / scale);
                translateY = y - dy * (newScale / scale);
                scale = newScale;
                updateTransform();
            }

            function fitView() {
                const containerRect = viewport.getBoundingClientRect();
                const wrapperRect = wrapper.getBoundingClientRect();
                let scaleX = (containerRect.width - 20) / wrapperRect.width;
                let scaleY = (containerRect.height - 20) / wrapperRect.height;
                // Zoom mínimo 0.85 para que el texto sea legible
                let newScale = Math.min(scaleX, scaleY, 1.8);
                newScale = Math.max(newScale, 0.85);
                scale = newScale;
                translateX = (containerRect.width - wrapperRect.width * scale) / 2;
                translateY = 20;
                updateTransform();
            }

            function resetView() {
                scale = 1;
                translateX = 0;
                translateY = 0;
                updateTransform();
            }

            // Eventos de ratón
            viewport.addEventListener('mousedown', (e) => {
                if (e.button !== 0) return;
                isDragging = true;
                startX = e.clientX;
                startY = e.clientY;
                startTranslateX = translateX;
                startTranslateY = translateY;
                viewport.style.cursor = 'grabbing';
                e.preventDefault();
            });
            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                translateX = startTranslateX + (e.clientX - startX);
                translateY = startTranslateY + (e.clientY - startY);
                updateTransform();
            });
            window.addEventListener('mouseup', () => {
                isDragging = false;
                viewport.style.cursor = 'grab';
            });

            // Rueda
            viewport.addEventListener('wheel', (e) => {
                e.preventDefault();
                zoomAt(e.deltaY < 0 ? 1 : -1, e.clientX, e.clientY);
            }, { passive: false });

            // Botones
            document.querySelector('.zoom-in')?.addEventListener('click', () => zoomAt(1, viewport.clientWidth / 2, viewport
                .clientHeight / 2));
            document.querySelector('.zoom-out')?.addEventListener('click', () => zoomAt(-1, viewport.clientWidth / 2,
                viewport.clientHeight / 2));
            document.querySelector('.fit-view')?.addEventListener('click', fitView);
            document.querySelector('.reset-view')?.addEventListener('click', resetView);

            // Toque
            let touchStart = null;
            viewport.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY, tx: translateX, ty: translateY };
                    isDragging = true;
                }
            });
            viewport.addEventListener('touchmove', (e) => {
                if (touchStart && e.touches.length === 1) {
                    translateX = touchStart.tx + (e.touches[0].clientX - touchStart.x);
                    translateY = touchStart.ty + (e.touches[0].clientY - touchStart.y);
                    updateTransform();
                    e.preventDefault();
                }
            });
            viewport.addEventListener('touchend', () => { touchStart = null;
                isDragging = false; });

            // Inicializar con vista ajustada
            setTimeout(fitView, 300);
        })();

