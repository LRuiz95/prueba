        function initFieldsModule() {
            const groups = new Map();
            for (const item of fieldsData) { if (!groups.has(item.owner)) groups.set(item.owner, []);
                groups.get(item.owner).push(item.field); }
            document.getElementById('total-depts').innerText = groups.size;
            let maxCount = 0,
                maxDeptName = '',
                exclusiveTotal = 0;
            for (let [dept, fields] of groups.entries()) { if (fields.length > maxCount) { maxCount = fields.length;
                    maxDeptName = dept; } if (fields.length === 1) exclusiveTotal++; }
            document.getElementById('max-dept').innerHTML =
                `${maxDeptName}<span class="text-[10px] block font-normal text-slate-500">${maxCount} campos</span>`;
            document.getElementById('exclusive-count').innerText = exclusiveTotal;
            const container = document.getElementById('accordion-container');
            if (!container) return;
            container.innerHTML = '';
            let idx = 0;
            for (let [dept, fields] of groups.entries()) {
                const deptId = `accordion-${idx}`;
                const card = document.createElement('div');
                card.className = 'border-b border-ui-border last:border-b-0';
                card.innerHTML =
                    `<div class="accordion-header px-6 py-4 flex justify-between items-center hover:bg-slate-50/80 transition-all" data-target="${deptId}"><div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-brand-50 flex items-center justify-center border border-brand-200"><i class="fa-solid fa-building text-brand-700 text-sm"></i></div><div><h3 class="font-bold text-slate-800">${dept}</h3><span class="text-[10px] font-mono text-slate-500">${fields.length} campos registrados</span></div></div><i class="fa-solid fa-chevron-down text-slate-400 transition-transform duration-200 chev-icon"></i></div><div id="${deptId}" class="accordion-content px-6 pb-4"><div class="flex flex-wrap gap-2 pt-2 border-t border-dashed border-ui-border mt-1"></div></div>`;
                container.appendChild(card);
                const contentDiv = card.querySelector(`#${deptId} .flex.flex-wrap`);
                fields.sort().forEach(f => { const tag = document.createElement('span');
                    tag.className = 'field-tag';
                    tag.innerHTML = `<i class="fa-regular fa-circle-check text-[10px] mr-1 text-slate-400"></i>${f}`;
                    contentDiv.appendChild(tag); });
                const header = card.querySelector('.accordion-header');
                const targetDiv = card.querySelector(`#${deptId}`);
                const chevron = header.querySelector('.chev-icon');
                let isOpen = false;
                header.addEventListener('click', () => { if (!isOpen) { targetDiv.classList.add('open');
                        targetDiv.style.maxHeight = targetDiv.scrollHeight + 'px';
                        chevron.style.transform = 'rotate(180deg)'; } else { targetDiv.classList.remove('open');
                        targetDiv.style.maxHeight = '0px';
                        chevron.style.transform = 'rotate(0deg)'; } isOpen = !isOpen; });
                idx++;
            }
            container.firstChild?.querySelector('.accordion-header')?.click();
        }
